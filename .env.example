# ============================================
# Wander Jr — Environment Configuration
# ============================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# --- Google Gemini (AI Studio) ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- PostgreSQL ---
POSTGRES_USER=wander
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=wander_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Opcional: se vazio, o projeto monta a URL automaticamente com os campos acima
DATABASE_URL=

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME=documents
QDRANT_SPARSE_VECTOR_NAME=sparse-vector

# --- Application ---
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME=Wander Jr
APP_DESCRIPTION=Assistente inteligente institucional do CEFET-MG campus Timóteo
APP_SERVICE_NAME=wander-jr
APP_ASSISTANT_NAME=Wander Jr
APP_INSTITUTION_NAME=CEFET-MG campus Timóteo
APP_SIGAA_URL=https://sig.cefetmg.br/sigaa/
APP_SECRETARIA_PHONE=(31) 3845-2005
APP_SECRETARIA_EMAIL=de.te@cefetmg.br
APP_DIRETORIA_EMAIL=diretoria-te@cefetmg.br
APP_SESSION_TIMEOUT_MINUTES=30
APP_MAX_HISTORY_TURNS=10

# --- RAG Settings ---
RAG_CHUNK_SIZE=420
RAG_CHUNK_OVERLAP=24
RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.35
RAG_CONFIDENCE_NONE_THRESHOLD=0.25
RAG_CONFIDENCE_LOW_THRESHOLD=0.5
RAG_DOCUMENTS_PATH=data/documents
RAG_SUPPORTED_EXTENSIONS=.pdf,.txt,.md
RAG_LIST_QUERY_MIN_TOP_K=8
RAG_PROMPT_HISTORY_TURNS=6

# --- LLM Settings ---
LLM_MODEL=gemini-2.5-flash
LLM_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-3-flash
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=10000
EMBEDDING_MODEL=models/gemini-embedding-2-preview
EMBEDDING_DIMENSIONS=768
EMBEDDING_REQUESTS_PER_MINUTE=5
EMBEDDING_MAX_RETRIES=3
EMBEDDING_BASE_RETRY_SECONDS=2.0
RAG_EMBEDDING_BATCH_SIZE=10

# --- Document Parsing ---
LLAMA_CLOUD_API_KEY=
LLAMA_PARSE_TIER=cost_effective

# --- Reranker ---
# true  = usa reranker
# false = desativa reranker (somente busca vetorial)
RERANKER_ENABLED=false
RERANKER_MODEL=ms-marco-MultiBERT-L-12
RERANKER_TOP_K=5
RERANKER_RETRIEVAL_MULTIPLIER=3

# --- Docker / Compose ---
APP_CONTAINER_NAME=wander-jr
APP_BIND_PORT=8000
APP_DOCUMENTS_MOUNT_PATH=/app/data/documents
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_CONTAINER_NAME=wander-postgres
POSTGRES_BIND_PORT=5436
QDRANT_IMAGE=qdrant/qdrant:latest
QDRANT_CONTAINER_NAME=wander-qdrant
QDRANT_CONTAINER_NAME_PROD=wander-qdrant-prod
HOST_DOCUMENTS_PATH=./data/documents
QDRANT_STORAGE_PATH=./data/qdrant_storage
QDRANT_SNAPSHOTS_PATH=./data/qdrant_snapshots

# --- Deploy ---
# Exemplo: ghcr.io/seu-usuario/wander-rag:latest
DOCKER_IMAGE=
