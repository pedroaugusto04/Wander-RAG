# ============================================
# Wander Jr — Environment Configuration
# ============================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# --- Google Gemini (AI Studio) ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- PostgreSQL ---
POSTGRES_USER=wander
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=wander_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://wander:your-secure-password-here@postgres:5432/wander_db

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=documents

# --- Application ---
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# --- RAG Settings ---
RAG_CHUNK_SIZE=420
RAG_CHUNK_OVERLAP=24
RAG_TOP_K=4
RAG_SCORE_THRESHOLD=0.35
RAG_CONFIDENCE_NONE_THRESHOLD=0.35
RAG_CONFIDENCE_LOW_THRESHOLD=0.6
RAG_DOCUMENTS_PATH=data/documents

# --- LLM Settings ---
LLM_MODEL=gemini-2.5-flash
LLM_FALLBACK_MODELS=gemini-3.1-flash-lite,gemma-3-12b
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=700
EMBEDDING_MODEL=models/gemini-embedding-2-preview
EMBEDDING_FALLBACK_MODELS=models/gemini-embedding-001
EMBEDDING_DIMENSIONS=512
EMBEDDING_REQUESTS_PER_MINUTE=20
EMBEDDING_MAX_RETRIES=8
RAG_EMBEDDING_BATCH_SIZE=24

# --- Document Parsing ---
LLAMA_CLOUD_API_KEY=
LLAMA_PARSE_TIER=cost_effective

# --- Reranker ---
RERANKER_ENABLED=true
RERANKER_MODEL=ms-marco-MultiBERT-L-12
RERANKER_TOP_K=5
RERANKER_RETRIEVAL_MULTIPLIER=3
